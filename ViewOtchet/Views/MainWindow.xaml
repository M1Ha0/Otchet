<Window x:Class="OtchetClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OtchetClient.Views"
        mc:Ignorable="d"
        Title="Отчет по студентам" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.3*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Height="70" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="11 0 0 0">
            <TextBlock Height="20" Width="240">Выбор группы</TextBlock>
            <ComboBox VerticalAlignment="Bottom" Height="30" Width="240" x:Name="GroupComboBox" 
                DisplayMemberPath="NameGroup" SelectedValuePath="IdGroup"
                SelectedValue="{Binding IdGroup}" ></ComboBox>   
        </StackPanel>
        <Label Grid.Row="1" Height="40" VerticalAlignment="Top"  HorizontalAlignment="Center">Выберите период отчета</Label>
        <StackPanel Grid.Row="1" HorizontalAlignment="Left" Margin="50 30 0 0">
            <Label>От</Label>
            <DatePicker Width="300" SelectedDate="{Binding StartDate}" DisplayDateEnd="{Binding EndDate}"/>
        </StackPanel>
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0 30 50 0">
            <Label>До</Label>
            <DatePicker Width="300" SelectedDate="{Binding EndDate}" DisplayDateStart="{Binding StartDate}"/>
        </StackPanel>
    </Grid>
</Window>
